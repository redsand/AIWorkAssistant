# Server
PORT=3050
NODE_ENV=development

# Authentication (required for protected routes)
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me
AUTH_SESSION_SECRET=change-me-in-production

# OpenCode API (required for chat)
OPENCODE_API_URL=https://opencode.ai/zen/go/v1
OPENCODE_API_KEY=your_opencode_api_key

# AI Provider (opencode | zai | ollama | openai)
AI_PROVIDER=opencode

# OpenAI — set AI_PROVIDER=openai to use
OPENAI_API_URL=https://api.openai.com/v1
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o
OPENAI_MAX_CONTEXT_TOKENS=128000

# Z.ai (GLM models) — set AI_PROVIDER=zai to use
ZAI_API_URL=https://api.z.ai/api/coding/paas/v4
ZAI_API_KEY=your_zai_api_key
ZAI_MODEL=GLM-5
ZAI_TEMPERATURE=0.95
ZAI_TOP_P=0.9

# Ollama (local and cloud models) — set AI_PROVIDER=ollama to use
OLLAMA_API_URL=http://localhost:11434
OLLAMA_API_KEY=
OLLAMA_MODEL=llama3
OLLAMA_TEMPERATURE=0.7
OLLAMA_MAX_CONTEXT_TOKENS=128000

# Per-model context limit overrides (JSON map of model name -> max tokens)
# Example: OLLAMA_MODEL_CONTEXT_LIMITS={"glm-5.1:cloud":202752,"llama3:70b":8192}
OLLAMA_MODEL_CONTEXT_LIMITS=

# Jira Cloud
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your_email@example.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_PROJECT_KEYS=PROJ,OTHER

# GitLab
GITLAB_BASE_URL=https://gitlab.com
GITLAB_TOKEN=your_gitlab_personal_access_token
GITLAB_DEFAULT_PROJECT=your/project-path
GITLAB_WEBHOOK_SECRET=your_webhook_secret_here

# Jitbit Helpdesk
JITBIT_ENABLED=false
JITBIT_BASE_URL=https://your-company.jitbit.com/helpdesk
JITBIT_API_TOKEN=your_jitbit_api_token
JITBIT_DEFAULT_CATEGORY_ID=

# Google Calendar OAuth2 (optional — see GOOGLE_CALENDAR_OAUTH_SETUP.md)
GOOGLE_CALENDAR_CLIENT_ID=your_google_client_id
GOOGLE_CALENDAR_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3050/auth/google/callback
GOOGLE_CALENDAR_API_KEY=your_google_api_key
GOOGLE_CALENDAR_CALENDAR_ID=primary

# Calendar Tunnel (for iPhone subscription — localtunnel or cloudflare)
TUNNEL_ENABLED=true
TUNNEL_PROVIDER=localtunnel
TUNNEL_SUBDOMAIN=
TUNNEL_DOMAIN=

# Discord Bot (optional — see DISCORD_SETUP.md)
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_application_id
DISCORD_GUILD_ID=your_discord_server_id

# Signal Bot (optional — see SIGNAL_SETUP.md)
SIGNAL_PHONE_NUMBER=+1234567890
SIGNAL_DATA_PATH=~/.config/Signal
SIGNAL_WEBHOOK_PORT=3001

# Microsoft 365 (STUB — not implemented, integration is dead code)
# MICROSOFT_TENANT_ID=your_tenant_id
# MICROSOFT_CLIENT_ID=your_client_id
# MICROSOFT_CLIENT_SECRET=your_client_secret
# MICROSOFT_REDIRECT_URI=http://localhost:3050/auth/microsoft/callback

# Policy Configuration
POLICY_APPROVAL_MODE=strict
POLICY_JIRA_AUTO_CLOSE=false
POLICY_CALENDAR_ALLOW_DELETE=false

# Feature Flags
ENABLE_CALENDAR_WRITE=false
ENABLE_JIRA_TRANSITIONS=true
ENABLE_GITLAB_WEBHOOKS=true

# Web Search (Tavily recommended, Google Custom Search as fallback)
TAVILY_API_KEY=your_tavily_api_key
GOOGLE_SEARCH_API_KEY=your_google_api_key
GOOGLE_SEARCH_ENGINE_ID=your_custom_search_engine_id

# Codex CLI (optional — for autonomous code implementation)
CODEX_CLI_PATH=codex

# Structured operational error log
ERROR_LOG_FILE=./logs/errors.jsonl

# Aicoder / Autonomous Agent Settings
AICODER_REPO=your-repo-name
AICODER_OWNER=your-org
AICODER_WORKSPACE=../your-repo
AICODER_AGENT=claude
AICODER_MODEL=
AICODER_SOURCE=auto
AICODER_LABEL=ready-for-agent
AICODER_POLL_MS=60000
AICODER_MAX_CYCLES=0
AICODER_MAX_REWORK=10
AICODER_STALE_TIMEOUT_MINUTES=120
AICODER_BASELINE_MAX_FIX=2
AICODER_UNIT_TEST_TIMEOUT=300000
AICODER_INTEGRATION_TEST_TIMEOUT=600000
CODEX_API_KEY=your_openai_api_key
CODEX_MODEL=o4-mini

# LSP (Language Server Protocol) - optional
LSP_ENABLED=true
LSP_TYPESCRIPT_COMMAND=typescript-language-server
LSP_TYPESCRIPT_ARGS=--stdio

# HAWK Incident Response (ir.hawk.io)
HAWK_IR_ENABLED=false
HAWK_IR_BASE_URL=https://ir.hawk.io
HAWK_IR_ACCESS_TOKEN=your-hawk-access-token
HAWK_IR_SECRET_KEY=your-hawk-secret-key

# Web Push (VAPID) — Generate keys with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_ADMIN_EMAIL=mailto:admin@ai-work-assistant.example

# Push Notification Polling
PUSH_POLL_INTERVAL_MIN=5
PUSH_ESCALATION_L2_MINUTES=5
PUSH_ESCALATION_L3_MINUTES=15

# Escalation email (SMTP)
ESCALATION_SMTP_HOST=
ESCALATION_SMTP_PORT=587
ESCALATION_SMTP_SECURE=false
ESCALATION_SMTP_USER=
ESCALATION_SMTP_PASS=
ESCALATION_EMAIL_FROM=alerts@ai-work-assistant.example
ESCALATION_EMAIL_TO=
ESCALATION_EMAIL_TO_L3=

# Azure Communication Services (email via M365)
ACS_CONNECTION_STRING=                          # endpoint=https://...;accesskey=...
ACS_SENDER_ADDRESS=                             # Verified sender (e.g., no-reply@yourdomain.com)

# Email provider: "auto" (prefer ACS, fall back to SMTP), "acs", or "smtp"
EMAIL_PROVIDER=auto

# Database
DATABASE_URL=sqlite:./data/app.db

# Audit Log
AUDIT_LOG_FILE=./logs/audit.log
AUDIT_LOG_LEVEL=info

# ClaimKit (RAG replacement)
# Master toggle to enable/disable ClaimKit for A/B comparison with existing RAG
CLAIMKIT_ENABLED=false
# LLM adapter: "memory" (in-process), "comparison" (uses main AI_PROVIDER), or "ollama" (dedicated local)
CLAIMKIT_LLM_PROVIDER=memory
# Dedicated Ollama settings for ClaimKit (isolates LLM calls from main chat stream)
CLAIMKIT_OLLAMA_API_URL=http://localhost:11434
CLAIMKIT_OLLAMA_API_KEY=
CLAIMKIT_OLLAMA_MODEL=llama3
# Redis connection URL for persistent stores (optional)
CLAIMKIT_REDIS_URL=
# Redis key prefix for namespacing
CLAIMKIT_REDIS_PREFIX=aiworkassistant
# Top-K results for retrieval
CLAIMKIT_TOP_K=10
# Minimum relevance score threshold (0.0 to 1.0)
CLAIMKIT_MIN_SCORE=0.0
# Max evidence items per compilation
CLAIMKIT_MAX_EVIDENCE_ITEMS=20
# Query timeout in milliseconds (default 120000). Increase if ClaimKit times out on slow LLM providers.
CLAIMKIT_QUERY_TIMEOUT_MS=120000
# Block server.listen() on ClaimKit init. true = process.exit(1) if init fails
# (strict, recommended for prod). false = log warning, continue with CK disabled
# until the 60s retry succeeds (lenient, recommended for dev).
CLAIMKIT_REQUIRE_INIT=true
# Block server.listen() until knowledge/codebase/graph ingestion completes.
# true = full store ready on first request (slower startup, recommended for prod).
# false = fire-and-forget ingestion after listen (faster startup, recommended for dev).
CLAIMKIT_BLOCK_ON_INGESTION=true

# ── ClaimKit LLM call policy ─────────────────────────────────────────
# Max attempts per LLM call inside ClaimKit (extractor, planner, verifier,
# contradiction detector). Backoff is exponential — 15s × 2^(attempt-1)
# capped at baseMs × 16. With the default 5 attempts at 15s base, the
# worst-case time per LLM stage is ~465s. Keep this at 2 unless you have
# a specific reason to retry more — that protects against rate-limit
# storms cascading across the parallel ZAI/Ollama traffic.
CLAIMKIT_LLM_MAX_ATTEMPTS=2
# Base timeout in milliseconds for the first attempt. 15s is generous for
# small claim-extraction calls; raise if you see frequent first-attempt
# timeouts in [ClaimKit LLM] logs.
CLAIMKIT_LLM_TIMEOUT_MS=15000

# Hard cap on the time the query path will wait for seed ingestion when
# CLAIMKIT_AWAIT_SEED=true. Without this, a slow LLM extractor on the
# CLAIMKIT_QUERY_SEED_LIMIT documents can stall the whole query for
# tens of minutes — observed in real production at 56 minutes for 15
# seeded docs. 12s is enough for a fast provider on a small seed list;
# slower providers should set CLAIMKIT_AWAIT_SEED=false instead and let
# seeding run in the background.
CLAIMKIT_SEED_TIMEOUT_MS=12000

# ── ClaimKit roadmap features (Ideas 1, 4) ───────────────────────────
# Fraction of live chat responses to run shadow grounding on. Populates
# rag_hallucination_rate / rag_grounded on comparison_cases without
# affecting foreground latency. 0 disables; 1.0 grounds every query.
# 0.5 = a healthy signal without doubling LLM load.
CLAIMKIT_LIVE_GROUNDING_RATE=0.5

# Gap-fill cascade (Idea 4): when CK confidence falls below this threshold
# AND missingEvidence is non-empty, run a second-pass knowledgeStore.search
# against each missing-evidence item. Lets CK act as the gap detector for
# RAG. 0 disables; 1.0 always cascades.
CLAIMKIT_GAP_FILL_THRESHOLD=0.5
# Max missingEvidence items to cascade per query. Each adds one knowledge-
# store search. Keep small to bound latency.
CLAIMKIT_GAP_FILL_MAX_QUERIES=3

# Musician Assistant (optional — see docs/musician-assistant.md)
# Enable the Musician Assistant module
MUSICIAN_ASSISTANT_ENABLED=false
# Audio file upload directory
MUSICIAN_AUDIO_UPLOAD_DIR=./data/audio/uploads
# Audio analysis output directory
MUSICIAN_AUDIO_ANALYSIS_DIR=./data/audio/analysis
# Generated audio output directory
MUSICIAN_GENERATED_AUDIO_DIR=./data/audio/generated
# Music generation (disabled by default, set true to enable)
MUSICIAN_GENERATION_ENABLED=false
# Generation provider: mock (default for tests), local, huggingface, external
MUSICIAN_GENERATION_PROVIDER=mock
# Max upload file size in MB
MUSICIAN_MAX_UPLOAD_MB=100
# Max generation duration in seconds
MUSICIAN_MAX_GENERATION_SECONDS=30
# Default audio sample rate
MUSICIAN_DEFAULT_SAMPLE_RATE=44100
# Basic Pitch transcription (requires Python dependencies)
MUSICIAN_ENABLE_BASIC_PITCH=false
# Essentia AI analysis (requires Python dependencies)
MUSICIAN_ENABLE_ESSENTIA=false
# MusicGen generation (requires Python dependencies)
MUSICIAN_ENABLE_MUSICGEN=false
# Python worker URL for remote processing
MUSICIAN_PYTHON_WORKER_URL=
# Hugging Face API token (required for huggingface provider)
HUGGINGFACE_API_TOKEN=
