{
  "name": "ai-assistant",
  "version": "0.1.0",
  "description": "Guarded productivity and engineering agent with AI Assistant integration",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:opencode": "tsx scripts/test-opencode.ts",
    "test:jira": "tsx scripts/test-jira.ts",
    "test:jira:basic": "tsx scripts/test-jira-basic.ts",
    "test:gitlab": "tsx scripts/test-gitlab.ts",
    "test:roadmap": "tsx scripts/test-roadmap.ts",
    "test:memory": "tsx scripts/test-memory.ts",
    "test:guardrails": "tsx scripts/test-guardrails.ts",
    "test:google-calendar": "tsx scripts/test-google-calendar.ts",
    "test:production": "tsx scripts/test-production.ts",
    "init:roadmap": "tsx scripts/init-roadmap.ts",
    "deploy": "bash scripts/deploy.sh",
    "deploy:production": "bash scripts/deploy.sh deploy production",
    "backup": "bash scripts/backup-system.sh",
    "ssl:generate": "bash scripts/generate-ssl-certs.sh",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "cli": "tsx src/cli/cli.ts",
    "bot:discord": "tsx src/integrations/discord/bot-server.ts",
    "bot:signal": "tsx src/integrations/signal/bot-server.ts",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "agent",
    "productivity",
    "jira",
    "gitlab",
    "ai-assistant",
    "engineering"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.1.3",
    "@types/uuid": "^10.0.0",
    "axios": "^1.7.9",
    "better-sqlite3": "^11.10.0",
    "commander": "^12.1.0",
    "discord.js": "^14.26.3",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.0",
    "googleapis": "^171.4.0",
    "localtunnel": "^2.0.2",
    "uuid": "^14.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/localtunnel": "^2.0.4",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
