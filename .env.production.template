# Production Environment Configuration Template
# Copy this file to .env.production and fill in the values

# Application Settings
NODE_ENV=production
PORT=3000

# OpenCode API Configuration
OPENCODE_API_KEY=your_opencode_api_key_here
OPENCODE_API_URL=https://opencode.ai/zen/go/v1

# Jira Integration
JIRA_BASE_URL=https://your-domain.atlassian.net/
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your-jira-api-token-here

# GitLab Integration
GITLAB_BASE_URL=https://gitlab.your-domain.com/
GITLAB_TOKEN=your-gitlab-token-here
GITLAB_WEBHOOK_SECRET=your-webhook-secret-here

# Microsoft 365 Integration
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_TENANT_ID=your-microsoft-tenant-id

# Discord Bot Configuration
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_application_id_here
DISCORD_GUILD_ID=your_server_id_here

# Signal Configuration
SIGNAL_PHONE_NUMBER=+1234567890
SIGNAL_DATA_PATH=~/.config/Signal
SIGNAL_WEBHOOK_PORT=3001

# Policy Engine Settings
POLICY_APPROVAL_MODE=strict

# Database Settings (if using PostgreSQL)
POSTGRES_DB=openclaw
POSTGRES_USER=openclaw
POSTGRES_PASSWORD=your-secure-postgres-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis Settings (if using Redis)
REDIS_PASSWORD=your-secure-redis-password
REDIS_HOST=redis
REDIS_PORT=6379

# Monitoring Settings
GRAFANA_PASSWORD=your-secure-grafana-password

# Security Settings
JWT_SECRET=your-jwt-secret-here
SESSION_SECRET=your-session-secret-here

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Backup Settings
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30

# SSL/TLS Settings
SSL_ENABLED=true
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# Feature Flags
ENABLE_ROADMAP_FEATURE=true
ENABLE_MEMORY_MANAGEMENT=true
ENABLE_GUARDRAILS=true
ENABLE_MONITORING=true
